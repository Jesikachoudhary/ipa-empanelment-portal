# Docker Environment Variables
# Copy this file to .env.docker and update with your values

# Application
APP_NAME=EmpanelmentAdmin
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=empanelment
DB_USERNAME=empanelment_user
DB_PASSWORD=empanelment_password
DB_ROOT_PASSWORD=root

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# Cache
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Mail (configure as needed)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@empanelment.local
MAIL_FROM_NAME="${APP_NAME}"

# Ports
APP_PORT=80
APP_SSL_PORT=443
DB_PORT=3306
REDIS_PORT=6379
